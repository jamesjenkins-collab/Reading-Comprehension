# Environment Variables — Required for all deployments

# PostgreSQL connection string (from Neon, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Gemini AI API key
GEMINI_API_KEY="your-gemini-api-key"

# Secret for signing JWT session tokens (generate with: openssl rand -hex 32)
JWT_SECRET="your-random-32-char-hex-secret"
